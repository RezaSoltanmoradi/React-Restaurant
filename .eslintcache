rn;\r\n        } else {\r\n            addItem({\r\n                productId: props.id,\r\n                name: props.name,\r\n                amount: amount,\r\n                price: props.price,\r\n            });\r\n        }\r\n    };\r\n    return (\r\n        <li className={styles.meal}>\r\n            <div>\r\n                <h3 className={styles.title}>{props.name}</h3>\r\n            </div>\r\n            <div className={styles.description}>{props.description}</div>\r\n            <div className={styles.footer}>\r\n                <MealItemForm id={props.id} onAddToCart={addToCartHandler} />\r\n                <div className={styles.text}>\r\n                    قیمت:\r\n                    <span className={styles.price}>{price}</span>\r\n                </div>\r\n            </div>\r\n            <hr />\r\n        </li>\r\n    );\r\n};\r\nexport default MealItems;\r\n","E:\\programming\\تمرینات\\8-React-max\\02-Restaurant\\src\\components\\Meals\\MealItem\\MealItemForm.jsx",[],"E:\\programming\\تمرینات\\8-React-max\\02-Restaurant\\src\\components\\UI\\Input.js",[],"E:\\programming\\تمرینات\\8-React-max\\02-Restaurant\\src\\helper\\apiHelper.js",[],["105","106"],"E:\\programming\\تمرینات\\8-React-max\\02-Restaurant\\src\\pages\\admin\\adminPage.jsx",[],["107","108"],"E:\\programming\\تمرینات\\8-React-max\\02-Restaurant\\src\\components\\Cart\\Checkout.jsx",[],"E:\\programming\\تمرینات\\8-React-max\\02-Restaurant\\src\\components\\UI\\Button.js",[],{"ruleId":"109","replacedBy":"110"},{"ruleId":"111","replacedBy":"112"},{"ruleId":"113","severity":1,"message":"114","line":8,"column":34,"nodeType":"115","messageId":"116","endLine":8,"endColumn":39},{"ruleId":"109","replacedBy":"117"},{"ruleId":"111","replacedBy":"118"},{"ruleId":"109","replacedBy":"119"},{"ruleId":"111","replacedBy":"120"},"no-native-reassign",["121"],"no-negated-in-lhs",["122"],"no-unused-vars","'items' is assigned a value but never used.","Identifier","unusedVar",["121"],["122"],["121"],[